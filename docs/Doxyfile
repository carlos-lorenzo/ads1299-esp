DOXYFILE_ENCODING      = UTF-8
PROJECT_NAME           = "ADS1299 ESP-IDF Driver"
PROJECT_BRIEF          = "ADS1299 SPI driver for ESP-IDF"
OUTPUT_DIRECTORY       = .

INPUT                  = ../include
FILE_PATTERNS          = *.h
RECURSIVE              = NO
EXCLUDE                =
EXCLUDE_PATTERNS       =

GENERATE_HTML          = NO
GENERATE_XML           = YES
XML_OUTPUT             = xml

FULL_PATH_NAMES        = YES
STRIP_FROM_PATH        = ..
STRIP_FROM_INC_PATH    = ../include

OPTIMIZE_OUTPUT_FOR_C  = YES
EXTENSION_MAPPING      = h=C

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

JAVADOC_AUTOBRIEF      = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_IF_INCOMPLETE_DOC = YES
WARN_NO_PARAMDOC       = NO
WARN_AS_ERROR          = NO
WARN_FORMAT            = "$file:$line: $text"
WARN_LOGFILE           =

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO

QUIET                  = YES
